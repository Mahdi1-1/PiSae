{
  "title": "pisae - Vue d'ensemble backend",
  "uid": "pisae-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Mémoire JVM utilisée (heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requêtes HTTP / seconde",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU process",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage{service=~\".+\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Uptime des services (secondes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Services UP (via /actuator/health)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "up{job=~\"eureka-server|api-gateway|userpi\"}",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
