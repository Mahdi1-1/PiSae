// Pipeline CI dédié au microservice suivi-service :
// build Maven + tests JUnit + JaCoCo + analyse SonarQube + image Docker
pipeline {
    agent any

    tools {
        maven 'Maven' // configured in Jenkins > Global Tool Configuration
    }

    environment {
        MODULE                = 'suivi-service'
        SONAR_TOKEN           = credentials('sonar-token')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Maven') {
            steps {
                dir(env.MODULE) {
                    sh 'mvn clean compile -B'
                }
            }
        }

        stage('Tests unitaires (JUnit)') {
            steps {
                dir(env.MODULE) {
                    sh 'mvn test -B'
                }
            }
            post {
                always {
                    junit "${env.MODULE}/target/surefire-reports/*.xml"
                    jacoco execPattern: "${env.MODULE}/target/jacoco.exec"
                }
            }
        }

        stage('Analyse SonarQube') {
            steps {
                dir(env.MODULE) {
                    withSonarQubeEnv('My SonarQube Server') { // nom configuré dans Jenkins > Configure System
                        sh """
                            mvn sonar:sonar \
                              -Dsonar.projectKey=pisae-${env.MODULE} \
                              -Dsonar.host.url=\${SONAR_HOST_URL} \
                              -Dsonar.login=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Package') {
            steps {
                dir(env.MODULE) {
                    sh 'mvn package -DskipTests -B'
                }
            }
        }
    }

    post {
        success {
            echo "CI ${env.MODULE} terminé avec succès — build #${BUILD_NUMBER}"
        }
        failure {
            echo "CI ${env.MODULE} a échoué — voir les logs ci-dessus"
        }
    }
}
